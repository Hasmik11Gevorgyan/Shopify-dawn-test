{% doc %}
  @prompt
    Create a fully responsive Shopify Liquid image banner section.
    
    Requirements:
    
    Build a customizable hero/image banner section where the background image is uploaded separately through the Shopify Theme Editor. Do not place any text inside the image itself.
    
    Desktop layout:
    - Full width hero banner.
    - Use a background image with cover sizing.
    - Keep the image composition similar to the reference:
      - Text content positioned on the left side.
      - Vertical alignment centered.
      - Large heading at the top.
      - Short description text below heading.
      - CTA button below the description.
    - The text block should have enough spacing so it does not overlap important image elements.
    - Add settings for adjusting:
      - text position (left / center / right)
      - vertical alignment
      - content width
      - padding
      - text colors
      - button styles
    
    Mobile responsive behavior:
    - On screens below 768px:
      - Change layout to match the second reference image.
      - Move all text content to the center.
      - Keep heading centered.
      - Keep description centered.
      - Keep button centered.
      - Reduce font sizes automatically.
      - Adjust image positioning so the product/image details remain visible.
      - Do not crop the important elements of the image.
      - Use mobile-specific image positioning controls.
    
    Shopify Theme Editor settings:
    Create editable schema settings for:
    - Desktop image upload
    - Mobile image upload (optional)
    - Heading text
    - Description text
    - Button label
    - Button link
    - Heading font size desktop/mobile
    - Description font size desktop/mobile
    - Text alignment
    - Overlay opacity
    - Section height desktop/mobile
    - Image position desktop/mobile
    - Content max width
    - Button background color
    - Button text color
    - Button border radius
    - Section top and bottom padding
    
    Technical requirements:
    - Generate clean Shopify Liquid code.
    - Use semantic HTML.
    - Use CSS media queries for responsive behavior.
    - Avoid JavaScript unless absolutely necessary.
    - Make all content editable from Shopify Customizer.
    - The section should work independently as a Shopify section file.
    - Ensure the text remains selectable HTML, not part of the image.
    - Optimize for mobile and desktop performance.
    
    The final result should recreate the provided design:
    Desktop: left aligned text over image.
    Mobile: centered text over image with the image repositioned like the mobile reference.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .ai-image-banner-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.section_height_desktop }}px;
    display: flex;
    align-items: {{ block.settings.vertical_alignment }};
    justify-content: {{ block.settings.text_alignment }};
  }

  .ai-image-banner-background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-image-banner-background-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ block.settings.image_position_x_desktop }}% {{ block.settings.image_position_y_desktop }}%;
  }

  .ai-image-banner-background-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, {{ block.settings.overlay_opacity }});
    z-index: 1;
  }

  .ai-image-banner-content-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: {{ block.settings.content_max_width }}px;
    padding: 40px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-image-banner-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size_desktop }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .ai-image-banner-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size_desktop }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 30px;
    line-height: 1.5;
  }

  .ai-image-banner-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 15px 40px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    transition: opacity 0.3s ease;
  }

  .ai-image-banner-button-{{ ai_gen_id }}:hover {
    opacity: 0.9;
  }

  .ai-image-banner-mobile-image-{{ ai_gen_id }} {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .ai-image-banner-container-{{ ai_gen_id }} {
      height: {{ block.settings.section_height_mobile }}px;
      align-items: center;
      justify-content: center;
    }

    .ai-image-banner-background-{{ ai_gen_id }} img {
      object-position: {{ block.settings.image_position_x_mobile }}% {{ block.settings.image_position_y_mobile }}%;
    }

    .ai-image-banner-desktop-image-{{ ai_gen_id }} {
      display: none;
    }

    .ai-image-banner-mobile-image-{{ ai_gen_id }} {
      display: block;
    }

    .ai-image-banner-content-{{ ai_gen_id }} {
      text-align: center;
      padding: 20px;
      max-width: 100%;
    }

    .ai-image-banner-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: 15px;
    }

    .ai-image-banner-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
      margin-bottom: 20px;
    }

    .ai-image-banner-button-{{ ai_gen_id }} {
      padding: 12px 30px;
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-image-banner-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-banner-container-{{ ai_gen_id }}">
    <div class="ai-image-banner-background-{{ ai_gen_id }}">
      {% if block.settings.image_desktop %}
        <img
          src="{{ block.settings.image_desktop | image_url: width: 2000 }}"
          alt="{{ block.settings.image_desktop.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_desktop.width }}"
          height="{{ block.settings.image_desktop.height }}"
          class="ai-image-banner-desktop-image-{{ ai_gen_id }}"
        >
      {% endif %}

      {% if block.settings.image_mobile %}
        <img
          src="{{ block.settings.image_mobile | image_url: width: 1000 }}"
          alt="{{ block.settings.image_mobile.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_mobile.width }}"
          height="{{ block.settings.image_mobile.height }}"
          class="ai-image-banner-mobile-image-{{ ai_gen_id }}"
        >
      {% elsif block.settings.image_desktop %}
        <img
          src="{{ block.settings.image_desktop | image_url: width: 1000 }}"
          alt="{{ block.settings.image_desktop.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_desktop.width }}"
          height="{{ block.settings.image_desktop.height }}"
          class="ai-image-banner-mobile-image-{{ ai_gen_id }}"
        >
      {% endif %}
    </div>

    <div class="ai-image-banner-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-image-banner-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.description != blank %}
        <div class="ai-image-banner-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
      {% endif %}

      {% if block.settings.button_label != blank and block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-image-banner-button-{{ ai_gen_id }}">
          {{ block.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image banner",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image (optional)"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Image banner"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Give customers details about the banner image(s) or content on the template.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Right"
        }
      ],
      "default": "flex-start"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Vertical alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "Top"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "flex-end",
          "label": "Bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "label": "Content max width",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "section_height_desktop",
      "label": "Section height",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "image_position_x_desktop",
      "label": "Image horizontal position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "image_position_y_desktop",
      "label": "Image vertical position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Mobile layout"
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Section height",
      "min": 300,
      "max": 700,
      "step": 50,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "image_position_x_mobile",
      "label": "Image horizontal position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "image_position_y_mobile",
      "label": "Image vertical position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading size desktop",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size mobile",
      "min": 16,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "description_size_desktop",
      "label": "Description size desktop",
      "min": 12,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_size_mobile",
      "label": "Description size mobile",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Background",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Image banner"
    }
  ]
}
{% endschema %}
