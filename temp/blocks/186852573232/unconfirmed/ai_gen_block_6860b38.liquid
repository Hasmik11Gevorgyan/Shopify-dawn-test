{% doc %}
  @prompt
    Create a modern, minimal announcement bar section for the Shopify Dawn theme.
    
    Requirements:
    
    - Full-width announcement bar.
    - Height: 48px on desktop, 44px on mobile.
    - White background.
    - Thin light gray bottom border.
    - Three-column layout using flexbox.
    
    Left column:
    - Small editable text for the brand name.
    - Font size: 12px.
    - Medium font weight.
    - Vertically centered.
    
    Center column:
    - Editable promotional message.
    - Center aligned.
    - Font size: 13px.
    - Hidden on small mobile screens if necessary.
    
    Right column:
    - Editable CTA button labeled "Choose Gift".
    - Yellow background (#FFD84D).
    - Black text.
    - Right arrow icon after the text.
    - Rounded corners (4px).
    - Smooth hover effect.
    
    The "Choose Gift" button must be fully functional:
    - The destination URL must be editable from the Theme Editor.
    - When clicked, it should navigate to the selected page, collection, product, or external URL using Shopify's URL setting.
    - If no link is selected, the button should be disabled or hidden gracefully.
    
    Theme settings:
    - Brand text
    - Promotional text
    - Button text
    - Button link (URL picker)
    - Background color
    - Text color
    - Button background color
    - Button text color
    
    Use Shopify Liquid best practices.
    Include a complete {% schema %}.
    Include responsive CSS.
    No JavaScript unless absolutely necessary.
    Compatible with the latest Shopify Dawn theme.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    border-bottom: 1px solid {{ block.settings.border_color }};
  }

  .ai-announcement-bar-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 48px;
    padding: 0 20px;
    max-width: 100%;
  }

  .ai-announcement-bar-left-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    flex: 0 0 auto;
  }

  .ai-announcement-bar-brand-{{ ai_gen_id }} {
    font-size: 12px;
    font-weight: 500;
    color: {{ block.settings.text_color }};
    margin: 0;
    white-space: nowrap;
  }

  .ai-announcement-bar-center-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1 1 auto;
    text-align: center;
    padding: 0 20px;
  }

  .ai-announcement-bar-message-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-announcement-bar-right-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex: 0 0 auto;
  }

  .ai-announcement-bar-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    font-size: 13px;
    font-weight: 500;
    text-decoration: none;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
    white-space: nowrap;
  }

  .ai-announcement-bar-button-{{ ai_gen_id }}:hover {
    opacity: 0.85;
  }

  .ai-announcement-bar-arrow-{{ ai_gen_id }} {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-bar-container-{{ ai_gen_id }} {
      height: 44px;
      padding: 0 16px;
    }

    .ai-announcement-bar-center-{{ ai_gen_id }} {
      display: none;
    }

    .ai-announcement-bar-brand-{{ ai_gen_id }} {
      font-size: 11px;
    }

    .ai-announcement-bar-button-{{ ai_gen_id }} {
      font-size: 12px;
      padding: 6px 12px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .ai-announcement-bar-center-{{ ai_gen_id }} {
      padding: 0 12px;
    }

    .ai-announcement-bar-message-{{ ai_gen_id }} {
      font-size: 12px;
    }
  }
{% endstyle %}

<announcement-bar-{{ ai_gen_id }} class="ai-announcement-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-announcement-bar-container-{{ ai_gen_id }}">
    <div class="ai-announcement-bar-left-{{ ai_gen_id }}">
      {% if block.settings.brand_text != blank %}
        <p class="ai-announcement-bar-brand-{{ ai_gen_id }}">{{ block.settings.brand_text }}</p>
      {% endif %}
    </div>

    <div class="ai-announcement-bar-center-{{ ai_gen_id }}">
      {% if block.settings.promo_message != blank %}
        <p class="ai-announcement-bar-message-{{ ai_gen_id }}">{{ block.settings.promo_message }}</p>
      {% endif %}
    </div>

    <div class="ai-announcement-bar-right-{{ ai_gen_id }}">
      {% if block.settings.button_link != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-announcement-bar-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
          <svg class="ai-announcement-bar-arrow-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      {% endif %}
    </div>
  </div>
</announcement-bar-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "brand_text",
      "label": "Brand text",
      "default": "BRAND"
    },
    {
      "type": "text",
      "id": "promo_message",
      "label": "Promotional message",
      "default": "Free shipping on orders over $50"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Choose Gift"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#E5E5E5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#FFD84D"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
