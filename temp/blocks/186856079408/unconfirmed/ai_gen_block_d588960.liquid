{% doc %}
  @prompt
    Create a modern minimalist product page template for the Shopify Dawn theme.
    
    Design a clean, premium fashion-style product page similar to luxury e-commerce stores.
    
    Layout:
    - Use a clean white background with generous spacing.
    - Display the product image on the left and the product information on the right on desktop.
    - Stack the content vertically on tablets and mobile devices.
    - Keep the layout balanced, modern, and easy to read.
    
    Product Information:
    - Display the product title.
    - Display the product price below the title.
    - Display the product description below the price.
    - Support rich text descriptions.
    
    Product Media:
    - Use Shopify's dynamic product media gallery.
    - Support multiple images and videos.
    - Allow image zoom.
    - Gallery should update correctly for the selected variant.
    
    Variants:
    - Display color variants as modern rectangular buttons.
    - Selected option should be visually highlighted.
    - Display size as a dropdown selector.
    - Variant selection must dynamically update the product image, price, availability, SKU, and Add to Cart button.
    
    Add to Cart:
    - Full-width black button with white text and a right arrow icon.
    - Button must add the currently selected variant to the cart.
    - Disable the button when the selected variant is unavailable.
    - Display sold-out status automatically.
    
    Dynamic Shopify Features:
    - Use Shopify dynamic product data only.
    - Do not hardcode any content.
    - Support products with any number of images, variants, colors, sizes, prices, inventory levels, and descriptions.
    - All links, buttons, images, prices, variants, and availability must update dynamically.
    - Fully compatible with Shopify's Product object and Variant Picker.
    
    Responsive Design:
    - The entire product page must be fully responsive.
    - Optimize the layout for desktop, tablet, and mobile.
    - Ensure images, typography, spacing, buttons, and variant selectors adapt smoothly to every screen size.
    
    Performance & Best Practices:
    - Follow Shopify Dawn coding standards.
    - Use semantic HTML.
    - Use Liquid best practices.
    - Use minimal JavaScript only when necessary.
    - Do not use external libraries.
    - Keep the code clean, reusable, and optimized.
    
    The final result should be a production-ready Shopify product template that is fully responsive, fully dynamic, accessible, and compatible with the latest Shopify Dawn theme.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-page-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-product-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.mobile_padding }}px;
  }

  .ai-product-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.grid_gap }}px;
    align-items: start;
  }

  .ai-product-media-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-product-media-{{ ai_gen_id }} img,
  .ai-product-media-{{ ai_gen_id }} video {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.media_radius }}px;
  }

  .ai-product-info-{{ ai_gen_id }} {
    position: sticky;
    top: 20px;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 400;
    margin: 0 0 {{ block.settings.element_spacing }}px;
    color: {{ block.settings.text_color }};
    letter-spacing: 0.5px;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    margin-bottom: {{ block.settings.element_spacing }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-price-{{ ai_gen_id }} .price--on-sale .price-item--regular {
    text-decoration: line-through;
    opacity: 0.6;
    margin-right: 10px;
  }

  .ai-product-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.6;
    margin-bottom: {{ block.settings.element_spacing }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-product-variants-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.element_spacing }}px;
  }

  .ai-variant-label-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 500;
    margin-bottom: 12px;
    display: block;
    color: {{ block.settings.text_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ai-variant-options-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 20px;
  }

  .ai-variant-button-{{ ai_gen_id }} {
    padding: 12px 24px;
    border: 1px solid {{ block.settings.variant_border_color }};
    background-color: transparent;
    color: {{ block.settings.text_color }};
    cursor: pointer;
    transition: all 0.2s ease;
    font-size: 14px;
    border-radius: {{ block.settings.variant_radius }}px;
  }

  .ai-variant-button-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.text_color }};
  }

  .ai-variant-button-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.text_color }};
    color: {{ block.settings.background_color }};
    border-color: {{ block.settings.text_color }};
  }

  .ai-variant-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-variant-select-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.variant_border_color }};
    background-color: transparent;
    color: {{ block.settings.text_color }};
    font-size: 14px;
    cursor: pointer;
    border-radius: {{ block.settings.variant_radius }}px;
  }

  .ai-product-form-{{ ai_gen_id }} {
    margin-top: {{ block.settings.element_spacing }}px;
  }

  .ai-add-to-cart-{{ ai_gen_id }} {
    width: 100%;
    padding: 18px 32px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    cursor: pointer;
    font-size: 16px;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    border-radius: {{ block.settings.button_radius }}px;
  }

  .ai-add-to-cart-{{ ai_gen_id }}:hover:not(:disabled) {
    background-color: {{ block.settings.button_hover_bg }};
  }

  .ai-add-to-cart-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-arrow-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  .ai-add-to-cart-{{ ai_gen_id }}:hover:not(:disabled) .ai-arrow-icon-{{ ai_gen_id }} {
    transform: translateX(4px);
  }

  .ai-product-sku-{{ ai_gen_id }} {
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.6;
    margin-top: 12px;
  }

  @media screen and (max-width: 989px) {
    .ai-product-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .ai-product-info-{{ ai_gen_id }} {
      position: static;
    }

    .ai-product-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.title_size }}px * 0.8);
    }

    .ai-product-price-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.price_size }}px * 0.9);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-product-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-variant-button-{{ ai_gen_id }} {
      padding: 10px 20px;
      font-size: 13px;
    }

    .ai-add-to-cart-{{ ai_gen_id }} {
      padding: 16px 28px;
      font-size: 14px;
    }
  }
{% endstyle %}

<product-page-{{ ai_gen_id }} class="ai-product-page-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-product-container-{{ ai_gen_id }}">
    <div class="ai-product-grid-{{ ai_gen_id }}">
      <div class="ai-product-media-{{ ai_gen_id }}">
        {% if product.media.size > 0 %}
          {% for media in product.media %}
            <div class="ai-media-item-{{ ai_gen_id }}" data-media-id="{{ media.id }}" style="{% if forloop.index > 1 %}display: none;{% endif %}">
              {% if media.media_type == 'image' %}
                <img
                  src="{{ media | image_url: width: 1200 }}"
                  alt="{{ media.alt | escape }}"
                  width="{{ media.width }}"
                  height="{{ media.height }}"
                  loading="{% if forloop.index == 1 %}eager{% else %}lazy{% endif %}"
                >
              {% elsif media.media_type == 'video' or media.media_type == 'external_video' %}
                {{ media | media_tag: image_size: '1200x', autoplay: true, loop: true, muted: true }}
              {% endif %}
            </div>
          {% endfor %}
        {% else %}
          <div class="ai-product-media-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>

      <div class="ai-product-info-{{ ai_gen_id }}">
        <h1 class="ai-product-title-{{ ai_gen_id }}">{{ product.title }}</h1>

        <div class="ai-product-price-{{ ai_gen_id }}">
          <div class="price">
            {% if product.compare_at_price > product.price %}
              <div class="price--on-sale">
                <span class="price-item price-item--regular">
                  {{ product.compare_at_price | money }}
                </span>
                <span class="price-item price-item--sale">
                  {{ product.price | money }}
                </span>
              </div>
            {% else %}
              <span class="price-item">
                {{ product.price | money }}
              </span>
            {% endif %}
          </div>
        </div>

        {% if product.description != blank %}
          <div class="ai-product-description-{{ ai_gen_id }}">
            {{ product.description }}
          </div>
        {% endif %}

        {% form 'product', product, id: 'product-form-' | append: ai_gen_id, class: 'ai-product-form-' | append: ai_gen_id %}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          {% unless product.has_only_default_variant %}
            <div class="ai-product-variants-{{ ai_gen_id }}">
              {% for option in product.options_with_values %}
                <div class="ai-variant-group-{{ ai_gen_id }}">
                  <label class="ai-variant-label-{{ ai_gen_id }}">
                    {{ option.name }}
                  </label>

                  {% if option.name == 'Color' or option.name == 'Colour' %}
                    <div class="ai-variant-options-{{ ai_gen_id }}" data-option-index="{{ option.position }}">
                      {% for value in option.values %}
                        <button
                          type="button"
                          class="ai-variant-button-{{ ai_gen_id }} {% if option.selected_value == value %}active{% endif %}"
                          data-option-value="{{ value | escape }}"
                          data-option-position="{{ option.position }}"
                        >
                          {{ value }}
                        </button>
                      {% endfor %}
                    </div>
                  {% else %}
                    <select
                      class="ai-variant-select-{{ ai_gen_id }}"
                      data-option-position="{{ option.position }}"
                    >
                      {% for value in option.values %}
                        <option
                          value="{{ value | escape }}"
                          {% if option.selected_value == value %}selected{% endif %}
                        >
                          {{ value }}
                        </option>
                      {% endfor %}
                    </select>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          {% endunless %}

          <button
            type="submit"
            class="ai-add-to-cart-{{ ai_gen_id }}"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            <span class="ai-button-text-{{ ai_gen_id }}">
              {% if product.selected_or_first_available_variant.available %}
                Add to Cart
              {% else %}
                Sold Out
              {% endif %}
            </span>
            <svg class="ai-arrow-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </button>

          {% if block.settings.show_sku and product.selected_or_first_available_variant.sku != blank %}
            <div class="ai-product-sku-{{ ai_gen_id }}">
              SKU: <span class="ai-sku-value-{{ ai_gen_id }}">{{ product.selected_or_first_available_variant.sku }}</span>
            </div>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </div>
</product-page-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductPage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.form = this.querySelector('form');
        this.variantButtons = this.querySelectorAll('.ai-variant-button-{{ ai_gen_id }}');
        this.variantSelects = this.querySelectorAll('.ai-variant-select-{{ ai_gen_id }}');
        this.submitButton = this.querySelector('.ai-add-to-cart-{{ ai_gen_id }}');
        this.buttonText = this.querySelector('.ai-button-text-{{ ai_gen_id }}');
        this.skuElement = this.querySelector('.ai-sku-value-{{ ai_gen_id }}');
        this.priceElement = this.querySelector('.ai-product-price-{{ ai_gen_id }} .price');
        this.mediaItems = this.querySelectorAll('.ai-media-item-{{ ai_gen_id }}');
        this.hiddenInput = this.querySelector('input[name="id"]');
        
        this.productData = {{ product | json }};
        this.currentOptions = this.getCurrentOptions();
      }

      connectedCallback() {
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.variantButtons.forEach(button => {
          button.addEventListener('click', (e) => {
            const position = e.target.dataset.optionPosition;
            const value = e.target.dataset.optionValue;
            
            this.querySelectorAll(`[data-option-position="${position}"]`).forEach(btn => {
              btn.classList.remove('active');
            });
            e.target.classList.add('active');
            
            this.currentOptions[position - 1] = value;
            this.updateVariant();
          });
        });

        this.variantSelects.forEach(select => {
          select.addEventListener('change', (e) => {
            const position = e.target.dataset.optionPosition;
            this.currentOptions[position - 1] = e.target.value;
            this.updateVariant();
          });
        });

        this.form.addEventListener('submit', (e) => {
          e.preventDefault();
          
          const formData = new FormData(this.form);
          
          fetch('/cart/add.js', {
            method: 'POST',
            body: formData
          })
          .then(response => response.json())
          .then(data => {
            window.dispatchEvent(new CustomEvent('cart:item-added'));
            
            if (window.theme && window.theme.cart) {
              window.theme.cart.refresh();
            }
          })
          .catch(error => {
            console.error('Error adding to cart:', error);
          });
        });
      }

      getCurrentOptions() {
        const options = [];
        
        this.variantButtons.forEach(button => {
          if (button.classList.contains('active')) {
            const position = parseInt(button.dataset.optionPosition);
            options[position - 1] = button.dataset.optionValue;
          }
        });
        
        this.variantSelects.forEach(select => {
          const position = parseInt(select.dataset.optionPosition);
          options[position - 1] = select.value;
        });
        
        return options;
      }

      updateVariant() {
        const variant = this.productData.variants.find(v => {
          return v.option1 === this.currentOptions[0] &&
                 v.option2 === this.currentOptions[1] &&
                 v.option3 === this.currentOptions[2];
        });

        if (variant) {
          this.hiddenInput.value = variant.id;
          
          this.updatePrice(variant);
          this.updateButton(variant);
          this.updateSKU(variant);
          this.updateMedia(variant);
        }
      }

      updatePrice(variant) {
        if (!this.priceElement) return;

        let priceHTML = '';
        
        if (variant.compare_at_price && variant.compare_at_price > variant.price) {
          priceHTML = `
            <div class="price--on-sale">
              <span class="price-item price-item--regular">
                ${this.formatMoney(variant.compare_at_price)}
              </span>
              <span class="price-item price-item--sale">
                ${this.formatMoney(variant.price)}
              </span>
            </div>
          `;
        } else {
          priceHTML = `
            <span class="price-item">
              ${this.formatMoney(variant.price)}
            </span>
          `;
        }
        
        this.priceElement.innerHTML = priceHTML;
      }

      updateButton(variant) {
        if (variant.available) {
          this.submitButton.disabled = false;
          this.buttonText.textContent = 'Add to Cart';
        } else {
          this.submitButton.disabled = true;
          this.buttonText.textContent = 'Sold Out';
        }
      }

      updateSKU(variant) {
        if (this.skuElement && variant.sku) {
          this.skuElement.textContent = variant.sku;
        }
      }

      updateMedia(variant) {
        if (!variant.featured_media) return;

        this.mediaItems.forEach(item => {
          item.style.display = 'none';
        });

        const targetMedia = this.querySelector(`[data-media-id="${variant.featured_media.id}"]`);
        if (targetMedia) {
          targetMedia.style.display = 'block';
        }
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return new Intl.NumberFormat('en-US', {
          style: 'currency',
          currency: '{{ cart.currency.iso_code }}'
        }).format(amount);
      }
    }

    customElements.define('product-page-{{ ai_gen_id }}', ProductPage{{ ai_gen_id }});
  })();
</script>

