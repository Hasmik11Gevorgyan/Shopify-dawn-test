                  height="{{ 800 | times: block.settings.image_ratio | divided_by: 100 }}"
                  class="ai-product-hotspot-grid__image-{{ ai_gen_id }}"
                >
              {% else %}
                <div class="ai-product-hotspot-grid__placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings[hotspot_1_enabled_key] %}
