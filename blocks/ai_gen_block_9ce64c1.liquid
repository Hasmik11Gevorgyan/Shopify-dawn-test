          assign hotspot_1_y_key = 'product_' | append: i | append: '_hotspot_1_y'
          assign hotspot_1_product_key = 'product_' | append: i | append: '_hotspot_1_product'
          
          assign hotspot_2_enabled_key = 'product_' | append: i | append: '_hotspot_2_enabled'
          assign hotspot_2_x_key = 'product_' | append: i | append: '_hotspot_2_x'
          assign hotspot_2_y_key = 'product_' | append: i | append: '_hotspot_2_y'
          assign hotspot_2_product_key = 'product_' | append: i | append: '_hotspot_2_product'
          
          assign hotspot_3_enabled_key = 'product_' | append: i | append: '_hotspot_3_enabled'
          assign hotspot_3_x_key = 'product_' | append: i | append: '_hotspot_3_x'
          assign hotspot_3_y_key = 'product_' | append: i | append: '_hotspot_3_y'
          assign hotspot_3_product_key = 'product_' | append: i | append: '_hotspot_3_product'
