</product-hotspot-grid-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductHotspotGrid{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.hotspots = this.querySelectorAll('.ai-hotspot-marker-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.hotspots.forEach((hotspot) => {
          const button = hotspot.querySelector('.ai-hotspot-marker__button-{{ ai_gen_id }}');
          const popup = hotspot.querySelector('.ai-hotspot-popup-{{ ai_gen_id }}');
          const closeButton = popup.querySelector('.ai-hotspot-popup__close-{{ ai_gen_id }}');

          button.addEventListener('click', (e) => {
            e.stopPropagation();
            
            this.querySelectorAll('.ai-hotspot-popup-{{ ai_gen_id }}').forEach((p) => {
              if (p !== popup) {
                p.classList.remove('active');
                const otherButton = p.parentElement.querySelector('.ai-hotspot-marker__button-{{ ai_gen_id }}');
                if (otherButton) {
                  otherButton.setAttribute('aria-expanded', 'false');
                }
              }
            });

            const isActive = popup.classList.contains('active');
            popup.classList.toggle('active');
            button.setAttribute('aria-expanded', !isActive);
          });

          closeButton.addEventListener('click', (e) => {
            e.stopPropagation();
            popup.classList.remove('active');
            button.setAttribute('aria-expanded', 'false');
          });

          popup.addEventListener('click', (e) => {
            e.stopPropagation();
          });
        });

        document.addEventListener('click', (event) => {
          if (
            !event.target.closest('.ai-hotspot-popup-{{ ai_gen_id }}') &&
            !event.target.closest('.ai-hotspot-marker__button-{{ ai_gen_id }}')
          ) {
            this.querySelectorAll('.ai-hotspot-popup-{{ ai_gen_id }}').forEach((popup) => {
              popup.classList.remove('active');
              const button = popup.parentElement.querySelector('.ai-hotspot-marker__button-{{ ai_gen_id }}');
              if (button) {
                button.setAttribute('aria-expanded', 'false');
              }
            });
          }
        });
      }
    }

    customElements.define('product-hotspot-grid-{{ ai_gen_id }}', ProductHotspotGrid{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product hotspot grid",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the look"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "spacing_below_heading",
      "label": "Spacing below",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
