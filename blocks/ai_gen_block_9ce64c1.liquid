                    aria-expanded="false"
                  >
                    <svg class="ai-hotspot-marker__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="4"/>
                    </svg>
                  </button>
                  <div class="ai-hotspot-popup-{{ ai_gen_id }} ai-hotspot-popup-{{ ai_gen_id }}--{{ block.settings.popup_position }}">
                    {% if hotspot_product != blank %}
                      {% if hotspot_product.featured_image %}
                        <img
                          src="{{ hotspot_product.featured_image | image_url: width: 400 }}"
                          alt="{{ hotspot_product.featured_image.alt | escape }}"
                          loading="lazy"
                          class="ai-hotspot-popup__image-{{ ai_gen_id }}"
                        >
                      {% else %}
                        <div class="ai-hotspot-popup__image-placeholder-{{ ai_gen_id }}">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                      <div class="ai-hotspot-popup__content-{{ ai_gen_id }}">
                        <h3 class="ai-hotspot-popup__title-{{ ai_gen_id }}">{{ hotspot_product.title }}</h3>
                        <p class="ai-hotspot-popup__price-{{ ai_gen_id }}">{{ hotspot_product.price | money }}</p>
                        {% if hotspot_product.description != blank %}
                          <p class="ai-hotspot-popup__description-{{ ai_gen_id }}">{{ hotspot_product.description | strip_html | truncate: 100 }}</p>
                        {% endif %}
                        <a href="{{ hotspot_product.url }}" class="ai-hotspot-popup__link-{{ ai_gen_id }}">View product</a>
                      </div>
                    {% endif %}
                    <button class="ai-hotspot-popup__close-{{ ai_gen_id }}" aria-label="Close">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                      </svg>
                    </button>
                  </div>
                </div>
              {% endif %}

              {% if block.settings[hotspot_3_enabled_key] %}
                {% assign hotspot_product = block.settings[hotspot_3_product_key] %}
                <div
                  class="ai-hotspot-marker-{{ ai_gen_id }}"
                  style="left: {{ block.settings[hotspot_3_x_key] }}%; top: {{ block.settings[hotspot_3_y_key] }}%;"
                  data-hotspot-id="item-{{ i }}-hotspot-3"
                >
                  <button
                    class="ai-hotspot-marker__button-{{ ai_gen_id }}"
                    aria-label="View product details"
                    aria-expanded="false"
                  >
                    <svg class="ai-hotspot-marker__icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                      <circle cx="12" cy="12" r="4"/>
                    </svg>
                  </button>
                  <div class="ai-hotspot-popup-{{ ai_gen_id }} ai-hotspot-popup-{{ ai_gen_id }}--{{ block.settings.popup_position }}">
                    {% if hotspot_product != blank %}
                      {% if hotspot_product.featured_image %}
                        <img
                          src="{{ hotspot_product.featured_image | image_url: width: 400 }}"
                          alt="{{ hotspot_product.featured_image.alt | escape }}"
                          loading="lazy"
                          class="ai-hotspot-popup__image-{{ ai_gen_id }}"
                        >
                      {% else %}
                        <div class="ai-hotspot-popup__image-placeholder-{{ ai_gen_id }}">
                          {{ 'product-1' | placeholder_svg_tag }}
                        </div>
                      {% endif %}
                      <div class="ai-hotspot-popup__content-{{ ai_gen_id }}">
                        <h3 class="ai-hotspot-popup__title-{{ ai_gen_id }}">{{ hotspot_product.title }}</h3>
                        <p class="ai-hotspot-popup__price-{{ ai_gen_id }}">{{ hotspot_product.price | money }}</p>
                        {% if hotspot_product.description != blank %}
