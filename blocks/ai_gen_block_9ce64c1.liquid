                    </button>
                  </div>
                </div>
              {% endif %}

              {% if block.settings[hotspot_2_enabled_key] %}
                {% assign hotspot_product = block.settings[hotspot_2_product_key] %}
                <div
                  class="ai-hotspot-marker-{{ ai_gen_id }}"
                  style="left: {{ block.settings[hotspot_2_x_key] }}%; top: {{ block.settings[hotspot_2_y_key] }}%;"
                  data-hotspot-id="item-{{ i }}-hotspot-2"
                >
